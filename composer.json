{
	"name": "phpgt/website",
	"description": "The public www.php.gt website and documentation",

	"require": {
		"php": ">=8.4",
		"phpgt/webengine": "dev-master",
		"phpgt/logger": "^1.1",
		"league/commonmark": "2.7.0",
		"scrivo/highlight.php": "^9.18"
	},

	"require-dev": {
		"phpunit/phpunit": "^12.2"
	},

	"autoload": {
		"psr-4": {
			"GT\\Website\\": "./class"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GT\\Website\\Test\\": "./test/phpunit"
		}
	},
	"config": {
		"audit": {
			"ignore": ["PKSA-21fb-n1x5-5nf7", "GHSA-4v6x-c7xx-hw9f", "PKSA-2cx9-ynrq-qdk3"]
		}
	}
}
